                        "rawSql": "SELECT record_date AS time,\n       SUM(CAST(SPLIT_PART(working_hours, ':', 1) AS FLOAT) + CAST(SPLIT_PART(working_hours, ':', 2) AS FLOAT) / 60.0) AS \"Total Hours\"\nFROM attendance_records\nWHERE $__timeFilter(record_date)\n  AND working_hours != ''\n  AND ('${employee:csv}' = 'All' OR personal_code = ANY(STRING_TO_ARRAY('${employee:csv}', ',')))\nGROUP BY record_date\nORDER BY record_date",
